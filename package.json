{
  "name": "saucelabs-mobile-qa",
  "version": "1.0.0",
  "description": "SauceLabs My Demo App E2E 자동화 (Appium + WebdriverIO + Mocha, POM 아키텍처)",
  "type": "commonjs",
  "scripts": {
    "test": "wdio run wdio.conf.js",
    "test:login": "wdio run wdio.conf.js --spec ./test/specs/01.login.spec.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test:report": "npm test ; npm run allure:generate && npm run allure:open"
  },
  "keywords": ["appium", "webdriverio", "mocha", "pom", "qa", "mobile-automation", "allure"],
  "license": "MIT",
  "devDependencies": {
    "@wdio/allure-reporter": "^8.40.0",
    "@wdio/appium-service": "^8.40.0",
    "@wdio/cli": "^8.40.0",
    "@wdio/local-runner": "^8.40.0",
    "@wdio/mocha-framework": "^8.40.0",
    "@wdio/spec-reporter": "^8.40.0",
    "allure-commandline": "^2.30.0"
  }
}
